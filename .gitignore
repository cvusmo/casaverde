# ============================================================
# Casaverde Project .gitignore
# Acris Software Ltd. Co. — 2025
# Purpose: Keep workspace clean, secure, and lightweight
# ============================================================

# --- Rust build outputs ---
/target/
/**/target/

# --- Build and dependency artifacts ---
**/*.rlib
**/*.rmeta
Cargo.lock
Cargo.toml.orig
/build_output/

# --- Runtime logs and telemetry ---
/logs/
/**/logs/
*.log
*.trace
*.tmp
*.bak

# --- TLS / security materials ---
*.crt
*.cert
*.key
*.pem
*.pfx
*.der
*.csr
*.srl

# --- Configuration and environment files ---
.env
.env.*
*.toml.local
config/*.local.*
config/private/*
**/config/local_*.toml

# --- Generated or cached assets ---
*.json.bak
*.json.old
**/__pycache__/
.cache/
tmp/
temp/
dist/
build/

# --- Development / IDE / Editor files ---
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.orig
*~
.DS_Store
Thumbs.db

# --- Simulation / local-only data ---
/casaverde_sim
/casaverde_sim/data/
/casaverde_sim/output/
/casaverde_app/test_data/
/casaverde_server/runtime/

# --- Sensitive backups / old states ---
**/old/
**/archive/
**/backup/

# --- Logs from external tools ---
clippy.log
audit.log
cargo-audit.log

# --- Node / Frontend assets (if any UI layer added) ---
node_modules/
package-lock.json
yarn.lock

# --- Git / tool metadata ---
.gitignore~
.gitattributes~
